rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidQuiz(data) {
      return data.keys().hasAll(['title', 'ownerId', 'status', 'createdAt', 'updatedAt'])
        && data.title is string && data.title.size() <= 200
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.status is string && data.status.matches('^(draft|published)$')
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }
    
    function isValidQuestion(data) {
      return data.keys().hasAll(['quizId', 'ownerId', 'text', 'order', 'options', 'createdAt', 'updatedAt'])
        && data.quizId is string && data.quizId.size() <= 128
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.text is string && data.text.size() <= 500
        && data.order is number
        && data.options is list
        && (data.options.size() == 0 || (data.options[0] is map && data.options[0].keys().hasAll(['id', 'text', 'points'])))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['quizId', 'ownerId', 'totalScore', 'responses', 'submittedAt'])
        && data.quizId is string && data.quizId.size() <= 128
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.totalScore is number
        && data.responses is map
        && data.submittedAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
    }

    match /quizzes/{quizId} {
      allow get: if isValidId(quizId) && (existing().status == 'published' || (isSignedIn() && existing().ownerId == request.auth.uid));
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(quizId)
                    && isValidQuiz(incoming())
                    && incoming().ownerId == request.auth.uid
                    && incoming().createdAt == request.time;
                    
      allow update: if isSignedIn() && isValidId(quizId)
                    && existing().ownerId == request.auth.uid
                    && isValidQuiz(incoming())
                    && incoming().ownerId == existing().ownerId
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time;
                    
      allow delete: if isSignedIn() && isValidId(quizId) && existing().ownerId == request.auth.uid;

      match /questions/{questionId} {
        allow get: if isValidId(quizId) && isValidId(questionId) && (existing().ownerId == request.auth.uid || get(/databases/$(database)/documents/quizzes/$(quizId)).data.status == 'published');
        allow list: if isValidId(quizId) && (resource.data.ownerId == request.auth.uid || get(/databases/$(database)/documents/quizzes/$(quizId)).data.status == 'published');
        
        allow create: if isSignedIn() && isValidId(quizId) && isValidId(questionId)
                      && isValidQuestion(incoming())
                      && incoming().ownerId == request.auth.uid
                      && incoming().quizId == quizId
                      && incoming().createdAt == request.time;
                      
        allow update: if isSignedIn() && isValidId(quizId) && isValidId(questionId)
                      && existing().ownerId == request.auth.uid
                      && isValidQuestion(incoming())
                      && incoming().ownerId == existing().ownerId
                      && incoming().quizId == existing().quizId
                      && incoming().createdAt == existing().createdAt
                      && incoming().updatedAt == request.time;
                      
        allow delete: if isSignedIn() && isValidId(quizId) && isValidId(questionId) && existing().ownerId == request.auth.uid;
      }
      
      match /submissions/{submissionId} {
        allow get: if isValidId(quizId) && isValidId(submissionId) && isSignedIn() && existing().ownerId == request.auth.uid;
        allow list: if isValidId(quizId) && isSignedIn() && resource.data.ownerId == request.auth.uid;
        
        allow create: if isValidId(quizId) && isValidId(submissionId)
                      && isValidSubmission(incoming())
                      && incoming().quizId == quizId
                      && incoming().submittedAt == request.time;
      }
    }
  }
}
